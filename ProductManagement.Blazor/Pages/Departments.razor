@page "/departments"
@inject IProductClient ProductClient

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">Department Management</h3>
        <button @onclick="LoadDepartments" class="btn btn-outline-secondary btn-sm d-flex align-items-center">
            <i class="bi bi-arrow-clockwise me-1"></i> Refresh List
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div>@_errorMessage</div>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-0">
            @if (_departments == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2 text-muted">Fetching departments...</p>
                </div>
            }
            else if (!_departments.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-building text-muted" style="font-size: 3rem;"></i>
                    <p class="mt-2 text-muted">No departments found. Start by adding one!</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Name</th>
                                <th>Location</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in _departments)
                            {
                                <tr>
                                    <td class="fw-bold">@d.Name</td>
                                    <td class="text-muted">@d.Location</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="card-title mb-0">Add New Department</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Department Name</label>
                    <input @bind="_newName" placeholder="e.g. Human Resources" class="form-control" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Location</label>
                    <input @bind="_newLocation" placeholder="e.g. Building A" class="form-control" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button @onclick="AddDepartment" class="btn btn-primary w-100">
                        <i class="bi bi-plus-lg me-1"></i> Add
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.02);
    }
    .card {
        border-radius: 0.75rem;
    }
    .card-header:first-child {
        border-radius: 0.75rem 0.75rem 0 0;
    }
</style>

@code {
    private IReadOnlyList<IGetDepartments_Departments>? _departments;
    private string _newName = "";
    private string _newLocation = "";
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDepartments();
    }

    private async Task LoadDepartments()
    {
        try
        {
            var result = await ProductClient.GetDepartments.ExecuteAsync();

            if (result.Errors.Any())
            {
                _errorMessage = "GraphQL Errors: " + string.Join(", ", result.Errors.Select(e => e.Message));
            }
            else
            {
                _departments = result.Data?.Departments;
                _errorMessage = null;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to load departments: " + ex.Message;
        }
        StateHasChanged();
    }

    private async Task AddDepartment()
    {
        if (string.IsNullOrWhiteSpace(_newName) || string.IsNullOrWhiteSpace(_newLocation))
        {
            _errorMessage = "Please enter a valid name and location.";
            return;
        }

        try
        {
            _errorMessage = null;
            var addResult = await ProductClient.AddDepartment.ExecuteAsync(_newName, _newLocation);

            if (addResult.Errors.Any())
            {
                _errorMessage = "Failed to add: " + string.Join(", ", addResult.Errors.Select(e => e.Message));
                return;
            }

            _newName = "";
            _newLocation = "";

            await LoadDepartments();
        }
        catch (Exception ex)
        {
            _errorMessage = "An error occurred while adding the department: " + ex.Message;
        }
    }
}
